<labwc_config>
	<core>
		<adaptiveSync>fullscreen</adaptiveSync>
		<allowTearing>fullscreenForced</allowTearing>
		<primarySelection>no</primarySelection>
	</core>

	<windowSwitcher>
		<osd style="thumbnail" />
	</windowSwitcher>

	<desktops number="5" popupTime="0" />

	<theme>
		<name>Adwaita-Papirus-Dark</name>
	    <titlebar layout=":menu,max,close" showTitle="yes" />
	    <cornerRadius>14</cornerRadius>
	    <dropShadows>yes</dropShadows>
		<font name="sans" size="11" />
	    <font place="ActiveWindow" weight="bold" />
	    <font place="MenuHeader" weight="bold" />
	</theme>

	<keyboard>
		<keybind key="W-Return"><action name="Execute" command="alacritty" /></keybind>
		<keybind key="W-Space"><action name="Execute" command="fuzzel" /></keybind>
		<keybind key="W-w"><action name="Execute" command="helium" /></keybind>
		<keybind key="W-g"><action name="Execute" command="~/.local/bin/status" /></keybind>
		<keybind key="W-x"><action name="Execute" command="~/.local/bin/power" /></keybind>
		<keybind key="F12"><action name="Execute" command="~/.local/bin/cycle-audio-output" /></keybind>
		<keybind key="W-BackSpace"><action name="Execute" command="makoctl dismiss" /></keybind>

		<keybind key="Print"><action name="Execute" command="~/.local/bin/screenshot all" /></keybind>
		<keybind key="C-Print"><action name="Execute" command="~/.local/bin/screenshot selection" /></keybind>
		<keybind key="S-Print"><action name="Execute" command="~/.local/bin/screenshot open-selection" /></keybind>
		<keybind key="W-c"><action name="Execute" command="hyprpicker --autocopy" /></keybind>

		<keybind key="XF86Explorer"><action name="Execute" command="alacritty -e lf" /></keybind>
		<keybind key="XF86HomePage"><action name="Execute" command="helium" /></keybind>
		<keybind key="XF86Calculator"><action name="Execute" command="alacritty -e qalc" /></keybind>
		<keybind key="XF86Tools"><action name="Execute" command="alacritty -e wiremix" /></keybind>
		<keybind key="XF86AudioPrev"><action name="Execute" command="playerctl previous" /></keybind>
		<keybind key="XF86AudioNext"><action name="Execute" command="playerctl next" /></keybind>
		<keybind key="XF86AudioPlay"><action name="Execute" command="playerctl play-pause" /></keybind>
		<keybind key="XF86AudioStop"><action name="Execute" command="playerctl stop" /></keybind>
		<keybind key="XF86AudioMute"><action name="Execute" command="wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle" /></keybind>
		<keybind key="XF86AudioLowerVolume"><action name="Execute" command="wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.05-" /></keybind>
		<keybind key="XF86AudioRaiseVolume"><action name="Execute" command="wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.05+" /></keybind>
		<keybind key="XF86MonBrightnessDown"><action name="Execute" command="brightnessctl set 2%- -n" /></keybind>
		<keybind key="XF86MonBrightnessUp"><action name="Execute" command="brightnessctl set 2%+" /></keybind>

		<keybind key="W-r"><action name="Reconfigure" /></keybind>
		<keybind key="W-q"><action name="Close" /></keybind>
		<keybind key="W-S-q"><action name="Kill" /></keybind>
		<keybind key="W-S-h"><action name="SnapToEdge" direction="left" /></keybind>
		<keybind key="W-S-j"><action name="SnapToEdge" direction="down" /></keybind>
		<keybind key="W-S-k"><action name="SnapToEdge" direction="up" /></keybind>
		<keybind key="W-S-l"><action name="SnapToEdge" direction="right" /></keybind>
		<keybind key="W-d"><action name="Lower" /></keybind>
		<keybind key="W-f"><action name="AutoPlace" policy="cursor" /></keybind>
		<keybind key="W-Tab"><action name="NextWindow" workspace="current" /></keybind>
		<keybind key="W-S-Tab"><action name="PreviousWindow" workspace="current" /></keybind>
		<keybind key="W-n"><action name="NextWindow" workspace="current" identifier="current"/></keybind>
		<keybind key="W-p"><action name="PreviousWindow" workspace="current" identifier="current"/></keybind>
		<keybind key="F11"><action name="ToggleFullscreen" /></keybind>
		<keybind key="W-m"><action name="ToggleMaximize" /></keybind>
		<keybind key="W-a"><action name="ToggleAlwaysOnTop" /></keybind>
		<keybind key="W-s"><action name="ToggleOmnipresent" /></keybind>
		<keybind key="W-Comma"><action name="FocusOutput" direction="left" /></keybind>
		<keybind key="W-Period"><action name="FocusOutput" direction="right" /></keybind>
		<keybind key="W-S-Comma"><action name="MoveToOutput" direction="left" /></keybind>
		<keybind key="W-S-Period"><action name="MoveToOutput" direction="right" /></keybind>
		<keybind key="W-1"><action name="GoToDesktop" to="1" /></keybind>
		<keybind key="W-2"><action name="GoToDesktop" to="2" /></keybind>
		<keybind key="W-3"><action name="GoToDesktop" to="3" /></keybind>
		<keybind key="W-4"><action name="GoToDesktop" to="4" /></keybind>
		<keybind key="W-5"><action name="GoToDesktop" to="5" /></keybind>
		<keybind key="W-S-1"><action name="SendToDesktop" to="1" /></keybind>
		<keybind key="W-S-2"><action name="SendToDesktop" to="2" /></keybind>
		<keybind key="W-S-3"><action name="SendToDesktop" to="3" /></keybind>
		<keybind key="W-S-4"><action name="SendToDesktop" to="4" /></keybind>
		<keybind key="W-S-5"><action name="SendToDesktop" to="5" /></keybind>
	</keyboard>

	<mouse>
		<default />

		<context name="All">
			<mousebind button="Middle" action="Scroll"></mousebind>
		</context>
	</mouse>

	<libinput>
		<device category="non-touch">
			<accelProfile>flat</accelProfile>
			<scrollMethod>onbutton</scrollMethod>
		</device>
	</libinput>

	<windowRules>
		<windowRule identifier="dragon-drop">
			<action name="ToggleOmnipresent" />
			<action name="ToggleAlwaysOnTop" />
			<action name="MoveToEdge" direction="down" snapWindows="no" />
			<action name="MoveToEdge" direction="right" snapWindows="no" />
		</windowRule>
	</windowRules>
</labwc_config>

