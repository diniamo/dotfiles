#!/bin/bash

options=(
  "$(date +%R)"
  --expire-time=2000
  --icon=time
  --print-id
)

id_path=/tmp/information-notification-id
[ -e "$id_path" ] && options+=(--replace-id="$(cat "$id_path")")

[ -e /sys/class/power_supply/BAT0 ] && options+=("$(cat /sys/class/power_supply/BAT0/capacity)% - $(cat /sys/class/power_supply/BAT0/status)")

notify-send "${options[@]}" > "$id_path"
