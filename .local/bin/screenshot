#!/bin/sh
set -e

case "$1" in
	monitor)
		read MONITOR
		grim -o "$MONITOR" - | wl-copy --type image/png
		;;
	window)
		read MONITOR
		read X Y WIDTH HEIGHT
		grim -g "$X,$Y ${WIDTH}x${HEIGHT}" - | wl-copy --type image/png
		;;
	selection)
		still -c 'slurp | grim -g - -' | wl-copy --type image/png
		;;
	open-selection)
		file="$(mktemp --suffix .png)"
		still -c "slurp | grim -g - '$file'"
		xdg-open "$file"
		;;
esac
