#!/bin/bash
set -euo pipefail

sinks="$(wpctl status --nick | sed -n '/Audio/,/^$/p' | sed -n '/Sinks/,/Sources/p')"

ids=()
target=
for (( i=1; i <= "$#"; ++i )); do
	match="$(grep -oP "[\* ] +(\d+)(?=\. \Q${!i}\E)" <<< "$sinks")"
	ids+=("$match")

	# i is 1 past the inserted ID's index (we are selecting the sink after the default)
	[[ "${match:0:1}" == "*" ]] && target="$i"
done
[[ "$target" == "${#ids[@]}" ]] && target=0
name_index="$((target + 1))"

wpctl set-default "${ids[$target]}"

id_path=/tmp/cycle-audio-output-notification-id
options=(
	"Audio Output" "${!name_index}"
	--icon audio-card
	--expire-time 2000
	--print-id
)
[[ -f "$id_path" ]] && options+=(--replace-id "$(cat "$id_path")")
notify-send "${options[@]}" > "$id_path"
