#!/bin/bash
set -euo pipefail

wpctl set-default "$(wpctl status | awk '
	BEGIN {audio = 0; sinks = 0; i = 0; idx = 0}
	!audio && /^Audio$/ {audio = 1; next}
	audio && /^ ├─ Sinks:$/ {sinks = 1; next}
	sinks && /^ │  $/ {exit}
	sinks {
		ids[i] = substr($2, 1, length($2) - 1)
		if ($2 == "*") idx = i + 1
		i += 1
	}
	END {print ids[idx == i ? 0 : idx]}
')"
