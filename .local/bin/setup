#!/bin/bash
set -euo pipefail

# Packages
packages=(
	# Graphics
	mesa-dri vulkan-loader
	# Compositor
	labwc kanshi
	# Services
	elogind polkit greetd tuigreet
	xdg-desktop-portal-wlr xdg-desktop-portal-gtk
	mako gammastep
	# Media
	pipewire alsa-pipewire wireplumber
	# CLI
	fish-shell zoxide man-pages-devel
	fd ripgrep eza curl wget patch trash-cli jq libnotify playerctl wl-clipboard xdg-utils
	git difftastic lazygit
	lf 7zip
	kakoune editorconfig
	wiremix spotify-player
	btop
	# GUI
	fuzzel dragon
	slurp grim hyprpicker
	mpv-mpris
	# Look
	font-inter noto-fonts-emoji
	papirus-icon-theme
	gsettings-desktop-schemas
	qt5ct qt6ct qt5-wayland qt6-wayland
)
devoid_packages=(
	# GUI
	alacritty
	helium mpv
	still
	# Look
	bibata-cursor-modern-classic lyth-mono-term-nerd-font
)

installed=()
while read package; do
	installed+=("${package%-*}")
done < <(xbps-query --list-manual-pkgs)
is_installed() {
	for p in "${installed[@]}"; do
		[[ "$p" == "$1" ]] && return 0
	done
	return 1
}

to_install=()
for package in "${packages[@]}"; do
	is_installed "$package" || to_install+=("$package")
done
[[ "${#to_install[@]}" > 0 ]] && sudo xbps-install -Sy "${to_install[@]}"

if [[ ! -e ~/.ssh/id_ed25519 ]]; then
	ssh-keygen -t ed25519 -f ~/.ssh/id_ed25519 -P ""

	echo "Add ~/.ssh/id_ed25519.pub to GitHub ssh keys..."
	read
fi

[[ ! -e ~/dev/devoid ]] && git clone git@github.com:diniamo/devoid.git ~/dev/devoid
cd ~/dev/devoid
	to_install=()
	for package in "${devoid_packages[@]}"; do
		if ! is_installed "$package"; then
			fd -qd1 "$package-" binpkgs || ./build "$package"
			to_install+=("$package")
		fi
	done
	[[ "${#to_install[@]}" > 0 ]] && sudo xbps-install -yR binpkgs "${to_install[@]}"
cd -

# Dotfiles
if [[ ! -e ~/.dot ]]; then
	git clone --bare git@github.com:diniamo/dotfiles.git ~/.dot
	git --git-dir ~/.dot --work-tree ~ config status.showUntrackedFiles no
	git --git-dir ~/.dot --work-tree ~ config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"
	git --git-dir ~/.dot --work-tree ~ checkout --force
fi

gsettings set org.gnome.desktop.interface color-scheme prefer-dark

[[ ! -e ~/.local/share/fisher/functions/fisher.fish ]] && fish -c "
	curl -L https://raw.githubusercontent.com/jorgebucaran/fisher/main/functions/fisher.fish | source
	fisher update
"
[[ ! -e ~/.config/fish/conf.d ]] && ln -s ~/.local/share/fisher/conf.d ~/.config/fish/conf.d
[[ "$SHELL" != /usr/bin/fish ]] && sudo chsh -s /usr/bin/fish "$USER"

# /etc
cd ~/.etc
	while read relative; do
		target=~/.etc/"$relative"
		link=/etc/"$relative"

		if [[ -e "$link" ]]; then
			if [[ "$(realpath "$link")" = "$target" ]]; then
				continue
			else
				sudo rm "$link"
			fi
		else
			sudo mkdir -p "$(dirname "$link")"
		fi

		sudo ln -s "$target" "$link"
	done < <(fd --type file .)
cd -

sudo mkdir -p /etc/alsa/conf.d
[[ ! -e /etc/alsa/conf.d/50-pipewire.conf         ]] && sudo ln -s /usr/share/alsa/alsa.conf.d/50-pipewire.conf /etc/alsa/conf.d/
[[ ! -e /etc/alsa/conf.d/99-pipewire-default.conf ]] && sudo ln -s /usr/share/alsa/alsa.conf.d/99-pipewire-default.conf /etc/alsa/conf.d/

# Services
[[ ! -e /var/service/dbus   ]] && sudo ln -s /etc/sv/dbus /var/service/
[[ ! -e /var/service/greetd ]] && sudo ln -s /etc/sv/greetd /var/service/

exit 0
