#!/bin/bash
set -euo pipefail

# Packages
packages=(
	# Graphics
	mesa-dri vulkan-loader
	# Compositor
	clang21 pkg-config wlroots0.19-devel
	slurp grim hyprpicker
	wlr-randr lswt
	# Services
	elogind polkit greetd tuigreet
	xdg-desktop-portal-wlr xdg-desktop-portal-gtk mako gammastep
	# Media
	pipewire alsa-pipewire wireplumber
	# CLI
	fish-shell zoxide man-pages-devel
	fd ripgrep eza curl wget patch trash-cli jq
	git difftastic lazygit
	lf 7zip xz
	kakoune editorconfig
	wiremix libnotify playerctl wl-clipboard xdg-utils
	# GUI
	foot fuzzel dragon
	mpv-mpris
	# Look
	font-inter noto-fonts-emoji
	papirus-icon-theme
	gsettings-desktop-schemas
	qt5-wayland qt6-wayland
)
devoid_packages=(
	# GUI
	helium mpv
	still
	# Look
	bibata-cursor-modern-classic lyth-mono-term-nerd-font
)

sudo xbps-install -Syu "${packages[@]}"

if [ ! -e ~/.ssh/id_ed25519 ]; then
	ssh-keygen -t ed25519 -f ~/.ssh/id_ed25519 -P ""

	echo "Add ~/.ssh/id_ed25519.pub to GitHub ssh keys..."
	read
fi

[ ! -e ~/dev/devoid ] && git clone git@github.com:diniamo/devoid.git ~/dev/devoid
cd ~/dev/devoid
	for package in "${devoid_packages[@]}"; do
		fd -qd1 "$package-" binpkgs || ./build "$package"
	done
	sudo xbps-install -yuR binpkgs "${devoid_packages[@]}"
cd -


# Dotfiles
if [ ! -e ~/.dot ]; then
	git clone --bare git@github.com:diniamo/dotfiles.git ~/.dot
	git --git-dir ~/.dot --work-tree ~ config status.showUntrackedFiles no
	git --git-dir ~/.dot --work-tree ~ config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"
	git --git-dir ~/.dot --work-tree ~ checkout --force
fi

[ ! -e ~/.config/fish/functions/fisher.fish ] && fish -c "
	curl -L https://raw.githubusercontent.com/jorgebucaran/fisher/main/functions/fisher.fish | source
	fisher update
"
[ "$SHELL" != /usr/bin/fish ] && sudo chsh -s /usr/bin/fish "$USER"

[ ! -e ~/.config/kak/bundle/kak-bundle ] && git clone https://codeberg.org/jdugan6240/kak-bundle.git ~/.config/kak/bundle/kak-bundle

# /etc
cd ~/.etc
	while read relative; do
		target=~/.etc/"$relative"
		link=/etc/"$relative"

		if [ -e "$link" ]; then
			if [ "$(realpath "$link")" = "$target" ]; then
				continue
			else
				sudo rm "$link"
			fi
		else
			sudo mkdir -p "$(dirname "$link")"
		fi

		sudo ln -s "$target" "$link"
	done < <(fd --type file .)
cd -

# Compositor
[ ! -e ~/dev/dwl ] && git clone git@github.com/diniamo/dwl.git ~/dev/dwl
cd ~/dev/dwl
	CC=clang CFLAGS=-O3 make all
	sudo make install
cd -

# Services
[ ! -e /var/service/dbus ] && sudo ln -s /etc/sv/dbus /var/service
[ ! -e /var/service/greetd ] && sudo ln -s /etc/sv/greetd /var/service

exit 0
